{
  "name": "eslint-plugin-github",
  "version": "0.0.0-dev",
  "type": "module",
  "description": "An opinionated collection of ESLint shared configs and rules used by GitHub.",
  "main": "lib/index.js",
  "entries": [
    "lib/formatters/stylish-fixes.js"
  ],
  "bin": {
    "eslint-ignore-errors": "bin/eslint-ignore-errors.js"
  },
  "scripts": {
    "eslint-check": "eslint-config-prettier .eslintrc.js",
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm run update:eslint-docs -- --check",
    "lint:js": "eslint .",
    "pretest": "mkdir -p node_modules/ && ln -fs $(pwd) node_modules/",
    "test": "npm run eslint-check && npm run lint && mocha \"tests/**/*.js\" \"tests/**/*.mjs\"",
    "update:eslint-docs": "eslint-doc-generator",
    "test-examples:legacy": "cd test-examples/legacy && npm install && npm run lint",
    "test-examples:flat": "cd test-examples/flat && npm install && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/github/eslint-plugin-github.git"
  },
  "author": "GitHub, Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/github/eslint-plugin-github/issues"
  },
  "homepage": "https://github.com/github/eslint-plugin-github#readme",
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.1.0",
    "@github/browserslist-config": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "aria-query": "^5.3.0",
    "eslint-config-prettier": ">=10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-escompat": "^3.11.4",
    "eslint-plugin-eslint-comments": "npm:@eslint-community/eslint-plugin-eslint-comments@^4.7.2",
    "eslint-plugin-i18n-text": "^1.0.1",
    "eslint-plugin-import": "npm:eslint-plugin-import-x@^4.16.2",
    "eslint-plugin-jsx-a11y": "npm:eslint-plugin-jsx-a11y-x@^0.2.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-rule-documentation": ">=1.0.0",
    "globals": "^16.0.0",
    "jsx-ast-utils": "^3.3.2",
    "prettier": "^3.0.0",
    "svg-element-attributes": "^1.3.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.1"
  },
  "prettier": "@github/prettier-config",
  "browserslist": "extends @github/browserslist-config",
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "files": [
    "bin/*",
    "lib/*"
  ],
  "devDependencies": {
    "@github/prettier-config": "0.0.6",
    "chai": "^6.0.1",
    "eslint": "^10.4.1",
    "eslint-doc-generator": "^2.2.2",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "mocha": "^11.0.1",
    "npm-run-all": "^4.1.5"
  }
}
